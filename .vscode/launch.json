{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "GDB: Depurar main.exe",
      "type": "cppdbg",
      "request": "launch",
      "program": "${fileDirname}\\main.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${fileDirname}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "gdb.exe",
      "setupCommands": [
        {
          "description": "Habilitar a formatação de exibição para gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "C/C++: g++.exe arquivo de build ativo"
    }
  ]
}
